{
  "name": "worktrail",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "worktrail": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22.5.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && mkdir -p dist/db/migrations && cp src/db/migrations/*.sql dist/db/migrations/ && chmod +x dist/cli.js",
    "worktrail": "tsx src/cli.ts",
    "test": "NODE_NO_WARNINGS=1 tsx --test tests/**/*.test.ts",
    "test:browser": "playwright test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p ui/tsconfig.json",
    "ui": "tsx src/server.ts",
    "ui:dev": "concurrently -k \"tsx watch src/server.ts\" \"vite --config ui/vite.config.ts\"",
    "ui:build": "vite build --config ui/vite.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {},
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^6.3.5",
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "concurrently": "^9.1.2",
    "prettier": "^3.8.4",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
